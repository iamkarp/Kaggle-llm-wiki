{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kg/schema/mistake.schema.json",
  "title": "Mistake",
  "allOf": [{"$ref": "node.base.schema.json"}],
  "properties": {
    "type": {"const": "mistake"},
    "what_happened": {"type": "string"},
    "why_wrong": {"type": "string"},
    "evidence_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "version": {"type": "string"},
          "features": {"type": "string"},
          "oof": {"type": "number"},
          "lb": {"type": "number"},
          "delta": {"type": "number"},
          "notes": {"type": "string"}
        }
      }
    },
    "fix": {"type": "array", "items": {"type": "string"}, "description": "Technique or Pattern ids that resolve this"},
    "general_rule": {"type": "string"},
    "detection_heuristic": {"type": "string"},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "triggered_in_competition_id": {"type": "string", "description": "Competition id"},
    "triggered_in_submission_id": {"type": "string", "description": "Submission id"},
    "root_cause_category": {
      "type": "string",
      "enum": ["overfitting", "leakage", "metric-mismatch", "distribution-shift", "bug", "resource", "validation-design", "feature-engineering", "ensemble-weighting", "compute-timeout"]
    },
    "prevention": {"type": "array", "items": {"type": "string"}, "description": "Pattern ids"}
  }
}
