{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kg/schema/competition.schema.json",
  "title": "Competition",
  "allOf": [{"$ref": "node.base.schema.json"}],
  "properties": {
    "type": {"const": "competition"},
    "platform": {"type": "string", "examples": ["kaggle", "drivendata", "aicrowd", "codalab"]},
    "host_org": {"type": "string", "description": "id of an Organization node"},
    "url": {"type": "string", "format": "uri"},
    "prize_usd": {"type": "number", "minimum": 0},
    "metric": {"type": "string", "description": "id of a Metric node"},
    "task_type": {"type": "string", "description": "id of a TaskType node"},
    "start_date": {"type": "string", "format": "date"},
    "end_date": {"type": "string", "format": "date"},
    "stage1_deadline": {"type": "string", "format": "date"},
    "stage2_deadline": {"type": "string", "format": "date"},
    "team_size": {"type": "integer", "minimum": 1},
    "team_members": {"type": "array", "items": {"type": "string"}, "description": "Person ids"},
    "solo": {"type": "boolean"},
    "final_rank": {"type": "integer", "minimum": 1},
    "final_percentile": {"type": "number", "minimum": 0, "maximum": 1},
    "total_teams": {"type": "integer", "minimum": 1},
    "best_lb_score": {"type": "number"},
    "best_cv_score": {"type": "number"},
    "best_submission_id": {"type": "string", "description": "Submission id"},
    "shake_up": {"type": "boolean", "description": "Whether public→private LB had significant shake-up"},
    "leakage_found": {"type": "boolean"},
    "leak_type": {"type": "string"},
    "data_modality": {"type": "string", "enum": ["tabular", "timeseries", "image", "text", "audio", "multimodal", "rl", "graph", "geospatial"]},
    "datasets": {"type": "array", "items": {"type": "string"}, "description": "Dataset ids"},
    "submissions": {"type": "array", "items": {"type": "string"}, "description": "Submission ids"},
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "lessons": {"type": "array", "items": {"type": "string"}, "description": "Mistake or Concept ids"}
  }
}
